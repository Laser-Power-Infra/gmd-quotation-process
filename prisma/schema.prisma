generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Enquiry {
  id               String   @id @default(cuid())

  docketNumber     String   @unique
  partyName        String
  enquiryDate      DateTime

  enquiryType      String?
  state            String?
  paymentTerms     String?
  inspection       String?
  pbg              String?
  utility          String?
  vaPercent        Float?
  orderStatus      String?
  closureStatus    String?

  attachments      Attachment[]
  items            EnquiryItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Attachment {
  id          String   @id @default(cuid())
  enquiryId   String
  enquiry     Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  name        String
  url         String
  type        String?
  size        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EnquiryItem {
  id            String   @id @default(cuid())

  enquiryId     String
  enquiry       Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  itemName      String
  quantity      Decimal

  itemType      String?
  moc           String?
  itemTypeSource String?
  mocSource      String?
  size          String?
  pnRating      String?
  operationType String?
  extension     String?
  bypass        String?
  productCost   Decimal?
  costRefCode   String?
  cost          Decimal?
  stockStatus   String?
  discount      Decimal?
  vaPercent     String?
  quotedRate    String?
  quotedRateGst String?
  itemNameMerge String?
  totalValue   String?
  deliverySchedule String?
  itemWiseTotalValue String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
model ExtensionCost {
  id        String   @id @default(cuid())
  length    String    @unique
  cost      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BypassCost {
  id        String   @id @default(cuid())
  size      String   @unique
  cost      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model PaymentTermsCost {
  id        String   @id @default(cuid())
  terms     String   @unique
  costPct   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model InspectionCost {
  id        String   @id @default(cuid())
  type      String   @unique
  costPct   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model PbgCost {
  id        String   @id @default(cuid())
  pbg       String   @unique
  costPct   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model TransportationCost {
  id        String   @id @default(cuid())
  state     String   @unique
  fullLoad  String
  partLoad  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}