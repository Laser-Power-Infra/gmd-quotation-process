generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Enquiry {
  id               String   @id @default(cuid())

  docketNumber     String   @unique
  partyName        String
  enquiryDate      DateTime

  enquiryType      String?
  state            String?
  paymentTerms     String?
  inspection       String?
  pbg              String?
  utility          String?
  vaPercent        Float?
  orderStatus      String?

  attachments      Attachment[]
  items            EnquiryItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Attachment {
  id          String   @id @default(cuid())
  enquiryId   String
  enquiry     Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  name        String
  url         String
  type        String?
  size        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EnquiryItem {
  id            String   @id @default(cuid())

  enquiryId     String
  enquiry       Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  itemName      String
  quantity      Decimal

  itemType      String?
  moc           String?
  size          String?
  pnRating      String?
  operationType String?
  extension     String?
  bypass        String?
  productCost   Decimal?
  costRefCode   String?
  cost          Decimal?
  stockStatus   String?
  discount      Decimal?
  vaPercent     String?
  quotedRate    String?
  itemNameMerge String?
  totalValue   String?
  itemWiseTotalValue String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
